{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Vahlame/cursor-obsidian-memory-guide/main/schema.json",
  "title": "cursor-obsidian-memory-guide manifest",
  "description": "Schema for the machine-readable manifest of this repository.",
  "type": "object",
  "required": [
    "schemaVersion",
    "name",
    "title",
    "description",
    "version",
    "primaryArtifact",
    "license",
    "platform",
    "architecture",
    "canonicalPaths",
    "scheduledTasks",
    "requiredOnUserMachine",
    "userInputsRequired"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string", "format": "uri" },
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "name": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?$"
    },
    "platform": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "enum": ["windows", "macos", "linux"] }
    },
    "language": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z]{2}$" }
    },
    "primaryArtifact": { "type": "string", "pattern": "\\.md$" },
    "intendedConsumer": { "type": "string" },
    "license": { "type": "string", "minLength": 1 },
    "topics": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" }
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "type", "audience", "purpose"],
        "additionalProperties": false,
        "properties": {
          "path": { "type": "string" },
          "type": {
            "type": "string",
            "enum": [
              "documentation",
              "prompt",
              "metadata",
              "legal",
              "schema",
              "example",
              "config",
              "ci"
            ]
          },
          "audience": {
            "type": "string",
            "enum": ["human", "ai-agent", "machine", "any"]
          },
          "purpose": { "type": "string" },
          "consumeAs": { "type": "string" },
          "sections": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        }
      }
    },
    "architecture": {
      "type": "object",
      "required": ["flow", "components"],
      "additionalProperties": false,
      "properties": {
        "flow": { "type": "string" },
        "components": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "canonicalPaths": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "vault": { "type": "string" },
        "mcpConfig": { "type": "string" },
        "mcpPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "healthEndpoint": { "type": "string", "format": "uri" },
        "sseEndpoint": { "type": "string", "format": "uri" }
      }
    },
    "scheduledTasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "everyMinutes", "purpose"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "everyMinutes": { "type": "integer", "minimum": 1 },
          "purpose": { "type": "string" }
        }
      }
    },
    "requiredOnUserMachine": {
      "type": "array",
      "items": { "type": "string" }
    },
    "userInputsRequired": {
      "type": "array",
      "items": { "type": "string" }
    },
    "doNotDoInThisRepo": {
      "type": "array",
      "items": { "type": "string" }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cursor": { "type": "string" },
        "windows": { "type": "array", "items": { "type": "string" } },
        "powershell": { "type": "array", "items": { "type": "string" } },
        "node": { "type": "array", "items": { "type": "string" } },
        "mcpServerPackage": {
          "type": "object",
          "required": ["name", "version"],
          "properties": {
            "name": { "type": "string" },
            "version": { "type": "string" }
          }
        }
      }
    }
  }
}
